# Template only. Keep real secrets in .env/.env.local (gitignored)
# and Vercel Project Settings -> Environment Variables.

# Local / Dev runtime values
BOT_TOKEN=
DATABASE_URL=

# Optional: production domain so webhook is stable (e.g. https://hsbexpo.vercel.app). If unset, VERCEL_URL is used.
# SELF_URL=https://your-app.vercel.app

# Production on Vercel should use the same key names:
# BOT_TOKEN=<prod bot token>
# DATABASE_URL=<prod database url>
# SELF_URL=https://your-app.vercel.app
